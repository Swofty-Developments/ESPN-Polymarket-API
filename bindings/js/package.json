{
  "name": "espn-polymarket-map",
  "version": "0.1.0",
  "description": "Map ESPN scoreboard games to Polymarket prediction markets (cross-language port; byte-identical to the Rust reference).",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "clean:test": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist-test',{recursive:true,force:true}))\"",
    "copy-data": "node ./scripts/copy-data.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && npm run copy-data",
    "build:test": "npm run clean:test && tsc -p tsconfig.test.json",
    "pretest": "npm run build && npm run build:test",
    "test": "node --test \"dist-test/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
